{
  "schema_version": 3,
  "id": "topology-first-year-2018-aug-part-1",
  "subject": "First Year Topology",
  "subject_tag": "topology-first-year",
  "year": 2018,
  "month": "august",
  "part": 1,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/MTG-5316-August-2018.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Answer the following problems and show all your work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that for every set \\(X\\), there is no function \\(f:X\\to 2^X\\) such that \\(f\\) is onto."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Suppose that \\(f:X\\to Y\\) is continuous and that \\(A\\subset X\\) is connected. Show that \\(f(A)\\subset Y\\) is connected."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(f,g:X\\to Y\\) be continuous maps to a Hausdorff space. Prove that the set \\(\\{x\\mid f(x)=g(x)\\}\\) is a closed subset of \\(X\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that if \\(X\\) is a compact Hausdorff space, then \\(X\\) is a normal space."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State and prove the Contraction Mapping Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that \\(\\{(a,b]\\mid a<b\\}\\) is a basis for a topology on \\(\\mathbb{R}\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give the definition of a quotient map."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that there is no continuous function \\(f:[0,1]\\to[0,1)\\) which is onto."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Does a connected space need to be path connected?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Intermediate Value Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Describe the one-point compactification of \\((0,1)\\cup(2,3)\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Urysohn Lemma."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Tietze Extension Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that if \\(A\\subset\\mathbb{R}\\) is connected then \\(A\\) is an interval."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Is \\(\\mathbb{R}^{\\omega}\\) connected in the uniform topology?"
          }
        ],
        "subparts": []
      }
    }
  ]
}
