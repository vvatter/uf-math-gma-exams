  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/FY-Topology-2-2021_08.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Work the following problems and show all work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that \\(S^2\\) is not homeomorphic to \\(S^4\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that the Stone–Čech compactification \\(\\beta X\\) of \\(X\\) is connected if and only if \\(X\\) is connected."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(X_{\\geq 0}\\), \\(Y_{\\geq 0}\\), and \\(Z_{\\geq 0}\\) denote the nonnegative parts of the \\(x\\)-axis, the \\(y\\)-axis, and the \\(z\\)-axis in \\(\\mathbb{R}^3\\) respectively. Let \\(A=\\mathbb{R}^3\\setminus(X_{\\geq 0}\\cup Y_{\\geq 0}\\cup Z_{\\geq 0})\\). Is the fundamental group \\(\\pi_1(A)\\) abelian?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that the torus \\(T\\) is not homeomorphic to the Klein bottle \\(K\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "By the definition the triod (or the letter T space) is a space homeomorphic to \\(X=([0,1]\\times\\{0\\})\\cup(\\{0\\}\\times[-1,1])\\subset\\mathbb{R}^2\\). Show that every continuous map of the triod to itself has a fixed point."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Does the sequence \\(f_n:\\mathbb{R}\\to\\mathbb{R}\\), \\(f_n(x)=\\ln\\left(x^{1/n}\\right)\\), converge in"
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "the point-wise convergence topology?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "the uniform topology?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "compact open topology?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Borsuk–Ulam Theorem for \\(S^2\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(X=\\mathbb{R}\\) and \\(A=\\mathbb{Z}\\) be the reals and the integers respectively. Is the quotient space \\(Y=X/A\\) metrizable?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Seifert–van Kampen Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Urysohn Lemma."
          }
        ],
        "subparts": []
      }
    }
  ]
}
