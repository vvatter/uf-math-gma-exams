  "content": [
    {
      "type": "instructions",
      "text": "For the first five problems, show all your work and support all statements."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Suppose that the continuous maps \\(f,g:X\\to Y\\) are homotopic and that the continuous maps \\(h,k:Y\\to Z\\) are homotopic. Show that \\(h\\circ f\\) is homotopic to \\(k\\circ g\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that \\(\\pi_1(S^1,1)\\cong\\mathbb{Z}\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State and prove the Brouwer fixed point theorem for the unit disk, \\(D^2\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that for \\(n\\geq 2\\), the fundamental group of the \\(n\\)-sphere, \\(S^n\\), is \\(0\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that the torus \\(T=S^1\\times S^1\\) is not homeomorphic to the surface of genus two, \\(M_2=T\\mathbin{\\#}T\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Suppose that \\(f,g:X\\to\\mathbb{R}^n\\) are continuous. Show that \\(f\\) and \\(g\\) are homotopic."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Borsuk–Ulam Theorem for \\(S^2\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Seifert–van Kampen Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Tietze Extension Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that \\(\\mathbb{R}^2\\) is not homeomorphic to \\(\\mathbb{R}^3\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Tychonoff theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Describe a space \\(X\\) with \\(\\pi(X)\\cong\\mathbb{Z}/3\\mathbb{Z}\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "If \\(j:A\\hookrightarrow X\\) is the inclusion of a retract, then show that the induced map on fundamental groups \\(j_\\#\\) is injective."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give the definition of a deformation retraction."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Define Stone–Čech compactification."
          }
        ],
        "subparts": []
      }
    }
  ]
}
