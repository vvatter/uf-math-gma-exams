{
  "schema_version": 3,
  "id": "topology-first-year-2018-jan-part-1",
  "subject": "First Year Topology",
  "subject_tag": "topology-first-year",
  "year": 2018,
  "month": "january",
  "part": 1,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/MTG-5316-January-2018.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Answer the following problems and show all your work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "A function \\(f:\\mathbb{N}\\to\\mathbb{Z}\\) is called eventually zero if there is some \\(N\\) such that \\(f(n)=0\\) for all \\(n\\geq N\\). Show that the set of functions \\(f:\\mathbb{N}\\to\\mathbb{Z}\\) that is eventually zero is countable."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(f:X\\to Y\\) be continuous and onto. Prove that if \\(X\\) is compact then so is \\(Y\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(f,g:X\\to Y\\) be continuous maps to a Hausdorff space. Prove that the set \\(\\{x\\mid f(x)=g(x)\\}\\) is a closed subset of \\(X\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that if \\(X\\) is a compact Hausdorff space, then \\(X\\) is a normal space."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State and prove the Contraction Mapping Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that \\(\\{[a,b)\\mid a<b\\}\\) is a basis for a topology on \\(\\mathbb{R}\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give the definition of a quotient map."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that there is no continuous map \\(f:\\mathbb{R}\\to\\{0,1\\}\\) that is surjective."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Does a connected space need to be path connected?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Intermediate Value Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Describe the one-point compactification of \\((0,1)\\cup(2,3)\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Urysohn Lemma."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Tietze Extension Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give an example of a space that is Hausdorff but not regular."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Is \\(\\mathbb{R}^{\\omega}\\) connected in the uniform topology?"
          }
        ],
        "subparts": []
      }
    }
  ]
}
