  "schema_version": 3,
  "id": "topology-first-year-2020-may-part-2",
  "subject": "First Year Topology",
  "subject_tag": "topology-first-year",
  "year": 2020,
  "month": "may",
  "part": 2,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/FY-Topology-2-2020_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Work the following problems and show all work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that \\(S^2\\) is not homeomorphic to \\(S^3\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that the set of irrational numbers \\(\\mathcal I\\subset\\mathbb R\\) cannot be presented as a countable union of closed sets each of which has empty interior in \\(\\mathcal I\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that for every continuous map \\(f:S^1\\to S^1\\) there is \\(n\\in\\mathbb Z\\) such that \\(f\\) is homotopic to \\(z^n:S^1\\to S^1\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that every map \\(f:S^2\\to T\\) of the 2-sphere to the torus \\(T\\) is null-homotopic."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that the torus \\(T\\) is not homeomorphic to the surface of genus 2, \\(M_2=T\\mathbin{\\#}T\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Does the sequence \\(f_n:\\mathbb R\\to\\mathbb R\\), \\(f_n(x)=\\sqrt{x}/n\\), converge in"
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "the point-wise convergence topology?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "the uniform topology?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "compact open topology?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Borsuk–Ulam Theorem for \\(S^2\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Is the space \\(I^I\\) separable where \\(I=[0,1]\\)?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Seifert–van Kampen Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State and prove the Tychonoff Theorem."
          }
        ],
        "subparts": []
      }
    }
  ]
}
