{
  "schema_version": 3,
  "id": "topology-first-year-2017-may-part-1",
  "subject": "First Year Topology",
  "subject_tag": "topology-first-year",
  "year": 2017,
  "month": "may",
  "part": 1,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/FY-Topology-1-2017_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Work the following problems and show all work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that the circle \\(S^1\\) is not homeomorphic to the closed 2-disk \\(B^2\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(A\\subset \\mathbb{R}^2\\) be an infinite countable subspace."
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "Can \\(A\\) be connected?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "Is \\(\\mathbb{R}^2\\setminus A\\) connected?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(f:X\\to\\mathbb{R}^2\\) be continuous injective map. Is \\(f\\) an embedding if"
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "\\(X=(0,1)\\)?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "\\(X=[0,1]\\)?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "\\(X=[0,1)\\)?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that a continuous injective map \\(f:(0,1)\\to\\mathbb{R}\\) is an embedding."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that every compact Hausdorff space is normal."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Describe all connected subsets of the real line \\(\\mathbb{R}\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Contraction Mapping Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(\\mathbb{R}_\\ell\\) denote the reals with the lower limit topology, i.e. topology defined by the basis \\(\\{[a,b)\\mid a,b\\in\\mathbb{R}\\}\\). Is \\(\\mathbb{R}_\\ell\\)"
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "connected?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "regular?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Baire Category Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that a connected metric space cannot be infinite countable."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Urysohn Lemma."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give definition of a quotient map."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Are the spaces \\((0,1)\\times[0,1)\\) and \\([0,1)\\times[0,1)\\) homeomorphic?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Describe the one-point compactification of \\(X=(0,1)\\cup(2,3)\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(X\\) be a locally connected space. Is every component of \\(X\\) closed?"
          }
        ],
        "subparts": []
      }
    }
  ]
}
