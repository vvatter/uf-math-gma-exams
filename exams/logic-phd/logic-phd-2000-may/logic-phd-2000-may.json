  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD_Logic_2000_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Answer 7 questions, including at least one from each of the four segments."
    },
    {
      "type": "section",
      "heading": "1. General Logic",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State Gödel’s incompleteness theorem, and explain the role of Gödel numbering in its proof."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Prove that there is no finite set \\(\\Gamma\\) of sentences in the language of groups such that a group \\(G\\) satisfies all the sentences in \\(\\Gamma\\) if and only if \\(G\\) is not torsion free. [The group \\(G\\) is torsion free if \\(g^n \\ne e\\) for all \\(g \\ne e\\) in \\(G\\).]"
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that any complete, finitely axiomatizable first-order theory is decidable."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Give an example of two models which are elementarily equivalent, but not isomorphic."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "2. Model Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and sketch a proof of the downward Löwenheim–Skolem theorem."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the omitting types theorem, and use it to prove that any \\(\\omega\\)-complete theory for arithmetic has an \\(\\omega\\)-model."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and sketch a proof of the Łoś theorem about ultraproducts of models."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "3. Set Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Prove that a countable union of countable sets is countable."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof that \\(L \\models \\mathrm{GCH}\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Prove that if \\(\\kappa\\) is a regular, uncountable cardinal then any diagonal intersection of closed and unbounded subsets of \\(\\kappa\\) is closed and unbounded."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "4. Recursion Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that a function \\(h: \\omega \\to \\omega\\) is (partial) recursive if and only if its graph is recursively enumerable; and that if \\(h\\) is total then its graph is recursive."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the halting problem, and prove that it is undecidable."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Explain why, for any \\(A \\subset \\omega\\), there are at most countably many sets \\(B\\) such that \\(B <_T A\\)."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
