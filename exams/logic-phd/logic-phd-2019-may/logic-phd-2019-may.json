  "schema_version": 3,
  "id": "logic-phd-2019-may",
  "subject": "PhD Logic",
  "subject_tag": "logic-phd",
  "year": 2019,
  "month": "may",
  "part": null,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD-Logic-2019_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Solve 5 problems of the following; at least one from each section."
    },
    {
      "type": "section",
      "heading": "A. Set Theory.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the construction of any model of ZFC and the Continuum Hypothesis."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Define the class of \\(\\Delta_0\\) formulas. Prove carefully that if \\(\\phi(x)\\) is a \\(\\Delta_0\\) formula with one free variable and \\(M\\) is any transitive set and \\(x \\in M\\), then \\(\\phi(x)\\) is equivalent to \\(M \\models \\phi(x)\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Provide an example of an analytic set which is not coanalytic. Provide a proof of these properties of the set."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "B. Computability.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Provide an example of a computably enumerable set which is not computable. Provide a proof of these properties of the set."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "What is Gödel’s diagonalization lemma? Prove the lemma."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "What is Post’s problem? Provide the answer to the Post’s problem and an outline of the proof."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "C. Model theory.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the downward Löwenheim–Skolem theorem and prove it."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the Łoś’ theorem and prove it."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Find a complete theory with more than one countable model up to isomorphism. Provide two nonisomorphic countable models of the theory."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
