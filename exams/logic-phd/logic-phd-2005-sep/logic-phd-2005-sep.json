  "content": [
    {
      "type": "instructions",
      "text": "Answer six questions and at least one from each section."
    },
    {
      "type": "section",
      "heading": "Section 1",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and prove the compactness theorem for propositional logic."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that the theory of the class of infinite sets (in the language of equality) is complete and decidable, but not finitely axiomatizable."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the Łoś Theorem for ultraproducts and sketch a proof."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 2",
      "numbering": "continue",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that Zorn’s Lemma implies that any set can be well-ordered."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch a proof that \\(ZFC \\cup \\{\\neg CH\\}\\) is consistent."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that any countable union of countable sets is countable."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 3",
      "numbering": "continue",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch a proof of Gödel’s incompleteness Theorem for Arithmetic."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that an infinite set \\(X \\subseteq \\omega\\) is the domain of a partial recursive function if and only if \\(X\\) is the range of \\(\\phi\\) for some partial recursive function \\(\\phi\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show how to construct a simple recursively enumerable set \\(A\\) (meaning that \\(\\omega-A\\) has no infinite r.e. subset)."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
