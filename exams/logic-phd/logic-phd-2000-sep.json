    {
      "type": "instructions",
      "text": "Answer 7 questions, including at least one from each of the four segments."
    },
    {
      "type": "section",
      "heading": "1. General Logic",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "text": "State Gödel’s incompleteness theorem, and briefly sketch its proof.",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "Show that any complete, finitely axiomatizable first-order theory is decidable.",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "Give an example of two countable models which are elementarily equivalent, but not isomorphic.",
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "2. Model Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "text": "State and sketch a proof of the completeness theorem.",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "State and sketch a proof of the Łoś theorem about ultraproducts of models.",
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "3. Set Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "text": "Prove that a countable union of countable sets is countable.",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "Sketch the proof that \\(L \\models \\mathrm{GCH}\\).",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "Prove that if \\(\\kappa\\) is a regular, uncountable cardinal then any diagonal intersection of closed and unbounded subsets of \\(\\kappa\\) is closed and unbounded.",
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "4. Recursion Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "text": "Show that any total function \\(f: \\omega \\to \\omega\\) with a recursively enumerable graph is recursive. Show that this is not true for partial functions.",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "Explain why, for any \\(A \\subset \\omega\\), there are at most countably many sets \\(B\\) such that \\(B <_T A\\).",
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "text": "State and prove Kleene’s Recursion (or Fixed Point) Theorem.",
            "subparts": []
          }
        }
      ]
    }
