  "content": [
    {
      "type": "instructions",
      "text": "Answer six questions, at least one in each section."
    },
    {
      "type": "section",
      "heading": "Section 1",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Provide a complete description of a formal proof system for first order logic."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof of the completeness theorem for first order logic."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and prove Gödel’s diagonal lemma."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 2",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof that the Continuum Hypothesis holds in the constructible universe \\(L\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that Zorn’s lemma implies the well-ordering principle."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof of consistency of the Continuum Hypothesis using forcing."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 3",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that every nonempty \\(\\Sigma_1\\)-definable set of natural numbers is the range of a total recursive function."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof of Friedberg–Muchnik theorem: there are two subsets of \\(\\omega\\) which are incomparable in the sense of the Turing ordering."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Explain what a simple set is and provide an example with a proof."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
