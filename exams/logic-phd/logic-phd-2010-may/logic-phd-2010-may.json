  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD_Logic_2010_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Answer six questions and at least one from each section."
    },
    {
      "type": "section",
      "heading": "Section 1",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch the proof of Gödel’s Completeness Theorem for Predicate Logic and explain the use of Henkin constants (or Skolem functions)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that the theory of the class of infinite sets is complete and decidable, but is not finitely axiomatizable."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch a proof of the Vaught test for categoricity using the Löwenheim–Skolem Theorem."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that if \\(A\\) and \\(B\\) are two countable atomic structures which are elementarily equivalent, then \\(A \\simeq_p B\\)."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 2",
      "numbering": "continue",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "(ZFC) For any infinite cardinal \\(\\kappa\\), \\(\\kappa \\times \\kappa = \\kappa\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Describe the constructible universe \\(L\\) and sketch a proof that \\(L\\) satisfies the Continuum Hypothesis."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that for any set \\(u\\) and any countable set \\(v\\), \\(FF(u,v)\\) satisfies the countable (anti)-chain condition."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "Section 3",
      "numbering": "continue",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Sketch a proof of Gödel’s incompleteness Theorem for Arithmetic. –You may assume the Representability Hypothesis."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Construct a simple r.e. set."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that the following are equivalent for any infinite \\(X \\subseteq \\omega\\):"
              }
            ],
            "subparts": [
              {
                "label": "(a)",
                "text": "\\(X\\) is recursively enumerable (that is, the range of a total recursive function);",
                "subparts": []
              },
              {
                "label": "(b)",
                "text": "\\(X\\) is semirecursive (there is a recursive relation \\(R\\) such that, for all \\(x\\), \\(x \\in X \\Longleftrightarrow (\\exists y)R(x,y)\\).",
                "subparts": []
              },
              {
                "label": "(c)",
                "text": "\\(X\\) is the domain of a partial recursive function.",
                "subparts": []
              }
            ]
          }
        }
      ]
    }
  ]
}
