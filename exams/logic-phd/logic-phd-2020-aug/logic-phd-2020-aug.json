{
  "schema_version": 3,
  "id": "logic-phd-2020-aug",
  "subject": "PhD Logic",
  "subject_tag": "logic-phd",
  "year": 2020,
  "month": "august",
  "part": null,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/logicphdexam120_2020_08.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Solve 5 problems of the following; at least one from each section."
    },
    {
      "type": "section",
      "heading": "A. Set Theory.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State Martin’s Axiom for \\(\\aleph_1\\) and prove that it implies the negation of the Continuum Hypothesis."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and prove Fodor’s pressing-down theorem."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Let \\(\\kappa\\) be an uncountable cardinal. Show that there is an ultrafilter on \\(\\kappa\\) containing no sets of cardinality smaller than \\(\\kappa\\)."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "B. Computability.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State two different common definitions of the class of computable functions and sketch the proof that they give the same class."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Define the many-one reducibility and sketch the proof that there is a many-one degree strictly between \\(0\\) and \\(0'\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Give an example of an infinite decidable structure and infinite undecidable structure and prove that they are such."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "C. Model theory.",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "What is quantifier elimination for theories? Give an example of a theory which has it, and prove that it has it."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the Łoś’ theorem and prove it."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and prove the Tarski criterion for elementarity of submodels."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
