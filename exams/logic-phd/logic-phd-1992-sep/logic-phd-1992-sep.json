{
  "schema_version": 3,
  "id": "logic-phd-1992-sep",
  "subject": "PhD Logic",
  "subject_tag": "logic-phd",
  "year": 1992,
  "month": "september",
  "part": null,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD_Logic_1992_09.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "This examination is divided into 4 segments, with 3 questions in each segment. Answer any 2 questions from each segment."
    },
    {
      "type": "section",
      "heading": "1. General Logic",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Prove that there is no single sentence \\(\\phi\\) in the language of ring theory such that a ring \\(R\\) is a model of \\(\\phi\\) if and only if \\(R\\) has characteristic 0."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and prove the compactness theorem for Predicate logic. You may assume the completeness theorem."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and sketch a proof of Gödel’s incompleteness theorem."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "2. Model Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that any two elementarily equivalent, countably saturated models are isomorphic."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State and sketch a proof of the downward Löwenheim–Skolem Theorem."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the Omitting types theorem, and use it to show that any \\(\\omega\\)-complete theory of arithmetic has an \\(\\omega\\)-model."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "3. Set Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that a countable union of countable sets is countable. Explain any use of the axiom of choice."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that \\(2^\\kappa = \\kappa^\\kappa\\) for all infinite \\(\\kappa\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Use Fodor’s theorem to prove that the diagonal intersection of a sequence of closed, unbounded sets is closed and unbounded."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
    {
      "type": "section",
      "heading": "4. Recursion Theory",
      "numbering": "restart",
      "content": [
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Show that a function \\(\\phi : \\omega \\to \\omega\\) is (partial) recursive iff its graph is recursively enumerable, and that if \\(\\phi\\) is total and recursive then its graph is recursive."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Prove that there is a subset of \\(\\omega\\) which is recursively enumerable but not recursive."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "State the normal form theorem for partial recursive functions and use it to prove the enumeration theorem."
              }
            ],
            "subparts": []
          }
        }
      ]
    }
  ]
}
