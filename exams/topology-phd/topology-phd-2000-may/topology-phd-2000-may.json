  "part": null,
  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD_Topology_2000_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Work the following problems and show all work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that there is no retraction of the Möbius band onto its boundary."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State and prove the Contraction Mapping Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give the Mayer–Vietoris sequence for homology. Use this to compute the homology groups for the \\(n\\)-sphere \\(S^n\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Suppose that \\(f,g:X\\to S^n\\) are two maps such that \\(f(x)\\) and \\(g(x)\\) are not antipodal for all \\(x\\in X\\). Show that \\(f\\) and \\(g\\) are homotopic."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that no covering space of the 2-torus has the homotopy type of a figure 8."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give a classification of the compact surfaces."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State Urysohn’s Lemma. State the Tietze Extension Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Five Lemma."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Define the mapping cylinder of \\(f:X\\to Y\\). Define the mapping torus of \\(f:X\\to X\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the exact homology sequence for a pair of spaces."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Jordan Curve Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Define retraction and deformation retraction."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Ascoli (Arzelà–Ascoli) Theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(V\\) be a complete metric space such that no point is isolated. Can \\(V\\) be a countably infinite set?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(A\\) be a countable subset of \\(\\mathbb{R}^2\\). Show that \\(\\mathbb{R}^2\\setminus A\\) is arcwise connected."
          }
        ],
        "subparts": []
      }
    }
  ]
}
