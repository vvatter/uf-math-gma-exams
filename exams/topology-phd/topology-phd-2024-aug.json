    {
      "type": "problem",
      "problem": {
        "text": "Let \\(X=\\mathbb{R}/\\mathbb{Z}\\) be the quotient space obtained from the real line \\(\\mathbb{R}\\) by collapsing the set of integers to a point.",
        "subparts": [
          {
            "label": "(a)",
            "text": "Is \\(X\\) metrizable?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "Does \\(X\\) admit a CW complex structure?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "Compute the fundamental group of \\(X\\).",
            "subparts": []
          },
          {
            "label": "(d)",
            "text": "Compute homology groups of \\(X\\).",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "text": "",
        "subparts": [
          {
            "label": "(a)",
            "text": "Prove that the 3-dimensional real projective space \\(\\mathbb{R}P^3\\) is orientable.",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "Does there exist a degree 2 continuous map \\(f:\\mathbb{R}P^3\\to T^3\\) where \\(T^3=S^1\\times S^1\\times S^1\\) is a 3-dimensional torus?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "Does there exist a degree 2 continuous map \\(f:T^3\\to\\mathbb{R}P^3\\)?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "text": "Let \\(A\\subset\\mathbb{R}^2\\) be an infinite countable subspace.",
        "subparts": [
          {
            "label": "(a)",
            "text": "Can \\(A\\) be connected?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "Is \\(\\mathbb{R}^2\\setminus A\\) connected?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "text": "Does there exist a closed orientable \\(n\\)-manifold \\(M\\) with",
        "subparts": [
          {
            "label": "(a)",
            "text": "\\(n=4\\) and \\(H_2(M)=\\mathbb{Z}\\)?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "\\(n=5\\) and \\(H_3(M)=\\mathbb{Z}\\)?",
            "subparts": []
          },
          {
            "label": "(c)",
            "text": "\\(n=6\\) and \\(H_3(M)=\\mathbb{Z}\\)?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "text": "Prove that the fundamental group of a topological group is abelian.",
        "subparts": []
      }
    },
    {
      "type": "instructions",
