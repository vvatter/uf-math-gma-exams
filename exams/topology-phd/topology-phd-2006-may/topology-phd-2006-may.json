  "pdf_url": "https://gma.math.ufl.edu/wp-content/uploads/sites/130/PhD_Topology_2006_05.pdf",
  "content": [
    {
      "type": "instructions",
      "text": "Work the following problems and show all work. Support all statements to the best of your ability."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Can a compact space contain a discrete infinite subspace?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that the product of two connected spaces is connected."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give an example of a space which is path connected but not locally connected."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Show that the Klein bottle with a deleted closed disk \\(K \\setminus D\\) is not a retract of \\(K\\)."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that the group \\(SO(n)\\) is connected in the matrix topology."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "instructions",
      "text": "Answer the following with complete definitions or statements or short proofs."
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Lefschetz fixed point theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Construct a map \\(f:S^3 \\to S^3\\) of degree 3."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Simplicial Approximation theorem."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Prove that for a path connected topological group \\(G\\) the Euler characteristic \\(\\chi(G)\\) is zero."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Does every function \\(f:\\mathbb{N} \\to \\mathbb{R}\\) admit a continuous extension \\(\\bar f:\\beta\\mathbb{N} \\to \\mathbb{R}\\) to the Stone–Čech compactification?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "What can you say about the \\(k\\)-homology groups of a closed orientable \\(n\\)-manifold for"
          }
        ],
        "subparts": [
          {
            "label": "(a)",
            "text": "\\(k=n\\)?",
            "subparts": []
          },
          {
            "label": "(b)",
            "text": "\\(k=n-1\\)?",
            "subparts": []
          }
        ]
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give a definition of the compact-open topology for the space of functions."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Let \\(j:S^1 \\subset S^4\\) be an embedding. Can \\(\\pi_1(S^4 \\setminus j(S^1))\\) be trivial? If it is not trivial, can the fundamental group \\(\\pi_1(S^4 \\setminus j(S^1))\\) be abelian?"
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "Give a definition of the wedge of a family of topological spaces. Prove that an infinite wedge of circles is not metrizable."
          }
        ],
        "subparts": []
      }
    },
    {
      "type": "problem",
      "problem": {
        "body": [
          {
            "type": "text",
            "text": "State the Contraction Mapping Theorem."
          }
        ],
        "subparts": []
      }
    }
  ]
}
