    {
      "type": "section",
      "heading": "III",
      "numbering": "restart",
      "content": [
        {
          "type": "instructions",
          "text": "Solve the following problems."
        },
        {
          "type": "instructions",
          "text": "Let \\((X,\\Sigma,\\mu)\\) be a measure space and \\(E\\) a Banach space."
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Assume \\(\\mu\\) is finite. Let \\(\\mathcal F\\subset\\Sigma\\) be a sub-\\(\\sigma\\)-algebra. Prove the existence of the conditional expectation \\(E(f\\mid\\mathcal F)\\) for functions \\(f\\in L_E^1(\\mu)\\)."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Let \\(\\mathcal R\\subset\\Sigma\\) be an algebra generating \\(\\Sigma\\) and \\(f\\in L_E^1(\\mu)\\). Prove that there is a sequence \\((f_n)\\) of \\(\\mathcal R\\)-step functions converging to \\(f\\), \\(\\mu\\)-a.e., and in the mean."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Let \\(\\mathcal R\\subset\\Sigma\\) be an algebra generating \\(\\Sigma\\) and \\(f\\in L_E^1(\\mu)\\). Prove that if \\(\\int_A f\\,d\\mu=0\\) for every \\(A\\in\\mathcal R\\), then \\(f=0\\), \\(\\mu\\)-a.e."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Assume \\(\\mu\\) is finite and let \\(f_n\\in L_E^1(\\mu)\\), \\(n=1,2,\\ldots\\). Prove that if \\(f_n\\to f\\) uniformly, then \\(f\\in L_E^1(\\mu)\\) and \\(f_n\\to f\\) in the mean."
              }
            ],
            "subparts": []
          }
        },
        {
          "type": "problem",
          "problem": {
            "body": [
              {
                "type": "text",
                "text": "Let \\((X,\\mathcal S)\\), \\((Y,\\mathcal T)\\) be measurable spaces, and let \\(\\mu:\\mathcal S\\to\\mathbb R\\) and \\(\\nu:\\mathcal T\\to\\mathbb R\\) be \\(\\sigma\\)-additive measures. Prove the existence of the product measure \\(\\mu\\times\\nu\\) and the equality \\(\\lvert\\mu\\times\\nu\\rvert=\\lvert\\mu\\rvert\\times\\lvert\\nu\\rvert\\)."
              }
            ],
            "subparts": []
          }
        }
      ]
    },
